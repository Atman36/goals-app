# Supabase project settings — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string used by Drizzle Kit + the db client (Supabase → Settings → Database → Connection string, "Transaction" pooler for serverless)
DATABASE_URL=

# Public site origin — builds the magic-link/OAuth redirect URLs (defaults to http://localhost:3000 if unset)
NEXT_PUBLIC_SITE_URL=

# Personal-product allowlist — only this email may sign in (PRD §3.8)
OWNER_EMAIL=

# Observability (P0, PRD §8.1)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Product analytics (P1, PRD §8.1)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
